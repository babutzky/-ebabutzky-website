---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header    from '../components/layout/Header.astro';
import Footer    from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Datenschutz – EBABUTZKY"
  description="Datenschutzerklärung gemäß DSGVO für ebabutzky.com."
  noindex={true}
>
  <Header />

  <main class="legal-page">
    <div class="section-inner legal-inner">

      <h1>Datenschutz&shy;erklärung</h1>

      <section class="legal-block">
        <h2>1. Datenschutz auf einen Blick</h2>
        <p>
          Die folgenden Hinweise geben einen Überblick darüber, was mit Ihren personenbezogenen
          Daten passiert, wenn Sie diese Website besuchen.
        </p>
      </section>

      <section class="legal-block">
        <h2>2. Hosting</h2>
        <p>
          <strong>Vercel</strong><br /><br />
          Vercel Inc.<br />
          440 N Barranca Ave #4133<br />
          Covina, CA 91723, USA<br /><br />
          Diese Website wird auf der Infrastruktur von Vercel betrieben.
          Beim Aufruf der Website werden Server-Logfiles (inkl. IP-Adresse,
          Zeitstempel, aufgerufene URL) verarbeitet.<br /><br />
          Rechtsgrundlage: Art. 6 Abs. 1 lit. f DSGVO<br />
          AV-Vertrag vorhanden.<br /><br />
          <a href="https://vercel.com/legal/privacy-policy" target="_blank" rel="noopener noreferrer">
            vercel.com/legal/privacy-policy
          </a>
        </p>
      </section>

      <section class="legal-block">
        <h2>3. Domain-Registrar &amp; E-Mail</h2>
        <p>
          <strong>IONOS</strong><br /><br />
          IONOS SE<br />
          Elgendorfer Str. 57<br />
          56410 Montabaur<br />
          Deutschland<br /><br />
          IONOS ist als Domain-Registrar für die Domain ebabutzky.com
          sowie als E-Mail-Dienstleister für die zugehörigen Postfächer
          (z. B. anfrage@ebabutzky.com) tätig.
          Ein Website-Hosting findet über IONOS nicht statt.<br /><br />
          Eingehende E-Mails werden auf Servern von IONOS in Deutschland
          verarbeitet und gespeichert.<br /><br />
          Rechtsgrundlage E-Mail-Verarbeitung: Art. 6 Abs. 1 lit. b DSGVO<br /><br />
          <a href="https://www.ionos.de/terms-gtc/datenschutzerklaerung/" target="_blank" rel="noopener noreferrer">
            ionos.de/terms-gtc/datenschutzerklaerung/
          </a>
        </p>
      </section>

      <section class="legal-block">
        <h2>4. DNS / Sicherheit</h2>
        <p>
          <strong>Cloudflare</strong><br /><br />
          Cloudflare Inc.<br />
          101 Townsend St.<br />
          San Francisco, CA 94107, USA<br /><br />
          Der DNS-Verkehr dieser Website wird über Cloudflare geleitet.
          Cloudflare fungiert dabei als DNS-Anbieter und Reverse-Proxy
          und verarbeitet IP-Adressen sowie technische Verbindungsdaten
          zum Zweck der Sicherheit und Performance.<br /><br />
          Rechtsgrundlage: Art. 6 Abs. 1 lit. f DSGVO<br /><br />
          <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">
            www.cloudflare.com/privacypolicy/
          </a>
        </p>
      </section>

      <section class="legal-block">
        <h2>5. Verantwortliche Stelle</h2>
        <p>
          EBabutzky GmbH<br />
          Schulstr. 39<br />
          73252 Lenningen<br />
          Deutschland<br /><br />
          Telefon: <a href="tel:+4970264241">+49 7026 4241</a><br />
          E-Mail: <a href="mailto:anfrage@ebabutzky.com">anfrage@ebabutzky.com</a>
        </p>
      </section>

      <section class="legal-block">
        <h2>6. Datenerfassung</h2>
        <p>
          <strong>Kontaktformular</strong><br />
          Die übermittelten Daten (Name optional, E-Mail, Anliegen) werden
          ausschließlich zur Bearbeitung Ihrer Anfrage verwendet.<br />
          Rechtsgrundlage: Art. 6 Abs. 1 lit. b DSGVO<br /><br />
          <strong>Kontakt per E-Mail / Telefon</strong><br />
          Verarbeitung zur Bearbeitung von Anfragen.
          E-Mails an anfrage@ebabutzky.com werden auf Servern von IONOS
          (Deutschland) empfangen und gespeichert.<br />
          Rechtsgrundlage: Art. 6 Abs. 1 lit. b DSGVO
        </p>
      </section>

      <section class="legal-block">
        <h2>7. Versanddienst für Kontaktanfragen</h2>
        <p>
          <strong>Resend</strong><br /><br />
          Resend, Inc.<br />
          2261 Market Street #5039<br />
          San Francisco, CA 94114<br />
          USA<br /><br />
          Kontaktanfragen über das Formular werden technisch über Resend zugestellt.
          Die eingegebenen Daten (Name optional, E-Mail, Anliegen) werden
          serverseitig verarbeitet und über die Infrastruktur von Resend
          weitergeleitet. Open Tracking und Click Tracking sind deaktiviert.<br /><br />
          Rechtsgrundlage: Art. 6 Abs. 1 lit. b DSGVO (Vertragsanbahnung)
          sowie Art. 6 Abs. 1 lit. f DSGVO.<br /><br />
          <a href="https://resend.com/legal/privacy-policy" target="_blank" rel="noopener noreferrer">
            resend.com/legal/privacy-policy
          </a>
        </p>
      </section>

      <section class="legal-block">
        <h2>8. Verschlüsselung</h2>
        <p>Diese Website nutzt SSL/TLS-Verschlüsselung.</p>
      </section>

      <section class="legal-block">
        <h2>9. Keine Tracking-Tools</h2>
        <p>
          Diese Website verwendet:<br />
          – keine Analyse-Tools<br />
          – keine Tracking-Dienste<br />
          – keine Marketing-Cookies
        </p>
      </section>

      <section class="legal-block">
        <h2>10. Ihre Rechte</h2>
        <p>
          Sie haben das Recht auf Auskunft, Berichtigung, Löschung und Einschränkung
          der Verarbeitung Ihrer personenbezogenen Daten sowie das Recht auf
          Datenübertragbarkeit und Widerspruch.<br /><br />
          Wenden Sie sich dazu an:
          <a href="mailto:anfrage@ebabutzky.com">anfrage@ebabutzky.com</a><br /><br />
          Zudem haben Sie das Recht, sich bei der zuständigen
          Datenschutz-Aufsichtsbehörde zu beschweren.
        </p>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .legal-page {
    background: var(--color-bg);
    min-height: 100vh;
    padding-top: calc(var(--header-offset) + 40px);
    padding-bottom: var(--section-y);
  }

  .legal-inner {
    max-width: 720px;
  }

  h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 0.96;
    color: var(--color-text);
    margin: 0 0 56px;
  }

  .legal-block {
    margin-bottom: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--color-border);
  }

  .legal-block:last-child {
    border-bottom: none;
  }

  h2 {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.42);
    margin: 0 0 16px;
  }

  p {
    margin: 0;
    color: rgba(255, 255, 255, 0.68);
    font-size: 1rem;
    line-height: 1.72;
  }

  strong {
    color: rgba(255, 255, 255, 0.86);
    font-weight: 600;
  }

  a {
    color: rgba(255, 255, 255, 0.72);
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.20);
    text-underline-offset: 3px;
    transition: color 0.18s ease;
  }

  a:hover {
    color: rgba(255, 255, 255, 0.92);
  }
</style>
