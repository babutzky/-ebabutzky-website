<div class="cookie-banner" data-cookie-banner aria-live="polite">
  <div class="cookie-banner__inner">
    <p class="cookie-banner__text">
      Diese Website verwendet keine externen Tracking-Dienste.
      Weitere Informationen in der <a href="/datenschutz">Datenschutzerklärung</a>.
    </p>
    <div class="cookie-banner__actions">
      <button class="cookie-banner__btn cookie-banner__btn--accept" data-cookie-accept>
        Verstanden
      </button>
      <a href="/datenschutz" class="cookie-banner__link">Mehr erfahren</a>
    </div>
  </div>
</div>

<script>
  const banner = document.querySelector('[data-cookie-banner]') as HTMLElement | null;
  const acceptBtn = document.querySelector('[data-cookie-accept]');

  const CONSENT_KEY = 'eb_cookie_consent';

  if (localStorage.getItem(CONSENT_KEY)) {
    banner?.remove();
  } else {
    banner?.classList.add('is-visible');
  }

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem(CONSENT_KEY, '1');
    banner?.classList.remove('is-visible');
    setTimeout(() => banner?.remove(), 400);
  });
</script>

