<section class="stats">
  <div class="section-inner">
    <div class="stats__grid">
      <div class="stat stat--primary reveal d1">
        <strong>25+</strong>
        <span>Jahre Erfahrung</span>
      </div>
      <div class="stat reveal d2">
        <strong>Bestand</strong>
        <span>Arbeit an bestehenden Systemen</span>
      </div>
      <div class="stat reveal d3">
        <strong>Sicherheit</strong>
        <span>Sicherer Betrieb</span>
      </div>
      <div class="stat reveal d4">
        <strong>Verantwortung</strong>
        <span>Vom Anschluss bis zum Betrieb</span>
      </div>
    </div>
  </div>
</section>

<style>
  .stats {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background: rgba(10, 10, 10, 0.78);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr 1fr;
  }

  .stat {
    padding: 22px 32px;
    border-right: 1px solid rgba(255, 255, 255, 0.11);
    transition: transform 0.18s cubic-bezier(0.22, 1, 0.36, 1);
    cursor: default;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .stat--primary {
    padding-left: 40px;
  }

  .stat:last-child { border-right: none; }

  .stat:hover { transform: translateY(-1px); }

  .stat strong {
    display: block;
    font-size: clamp(1.42rem, 2vw, 2.02rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: rgba(255, 255, 255, 0.94);
    margin-bottom: 8px;
  }

  /* „25+" dominant */
  .stat--primary strong {
    font-size: clamp(2.6rem, 4vw, 3.6rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.97;
    margin-bottom: 10px;
    color: #ffffff;
  }

  .stat span {
    display: block;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.52);
  }


  @media (max-width: 980px) {
    .stats__grid { grid-template-columns: 1fr 1fr; }
    .stat:nth-child(2) { border-right: none; }
    .stat:nth-child(1),
    .stat:nth-child(2) { border-bottom: 1px solid rgba(255, 255, 255, 0.11); }
  }

  @media (max-width: 640px) {
    .stats__grid { grid-template-columns: 1fr; }
    .stat {
      border-right: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.11);
      padding: 16px 0;
    }
    .stat:last-child { border-bottom: none; }
  }
</style>
